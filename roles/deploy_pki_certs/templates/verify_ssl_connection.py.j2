import argparse
import http.client
import logging
import sys
import ssl
import urllib.parse

# Setup fallback tracking for optional imports
HAS_REQUESTS = False
HAS_TRUSTSTORE = False

try:
    import requests

    HAS_REQUESTS = True
except ImportError:
    pass

try:
    import truststore

    HAS_TRUSTSTORE = True
except ImportError:
    pass


# =============================================================================
# Configuration & Logging
# =============================================================================
{% raw %}

def setup_logging(verbose: bool = False):
    """Sets up standard logging outputs based on verbosity."""
    log_level = logging.DEBUG if verbose else logging.INFO
    logging.basicConfig(
        level=log_level,
        format="%(asctime)s [%(levelname)s] %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
        handlers=[logging.StreamHandler(sys.stdout)]
    )


def validate_with_http_client(url: str) -> bool:
    """Validate SSL connection using http.client (standard library)."""
    parsed_url = urllib.parse.urlparse(url)
    conn = None
    logging.info(f"Testing SSL verification with standard http.client to: {url}")
    try:
        # Note: http.client naturally respects system/OS trust stores
        conn = http.client.HTTPSConnection(parsed_url.netloc, context=ssl.create_default_context())
        conn.request("GET", parsed_url.path or '/')
        response = conn.getresponse()
        logging.info(f"✓ Success with http.client: Status Code {response.status}")
        return True
    except ssl.SSLCertVerificationError as e:
        logging.error(f"✗ SSL Verification Error with http.client: {e}")
    except Exception as e:
        logging.error(f"✗ Connection Error with http.client: {e}")
    finally:
        if conn:
            conn.close()
    return False


def validate_with_requests(url: str) -> bool:
    """Validate SSL connection using the requests library."""
    if not HAS_REQUESTS:
        logging.warning("requests library not found. Skipping validation with requests.")
        return True

    logging.info(f"Testing SSL verification with requests to: {url}")

    if HAS_TRUSTSTORE:
        logging.debug("Injecting truststore into ssl context for requests to respect OS Trust Store.")
        truststore.inject_into_ssl()
    else:
        logging.warning("truststore library not installed. requests will fall back to static certifi bundle.")

    try:
        response = requests.get(url, timeout=10)
        response.raise_for_status()
        logging.info(f"✓ Success with requests: Status Code {response.status_code}")
        return True
    except requests.exceptions.SSLError as e:
        logging.error(f"✗ SSL Verification Error with requests: {e}")
        if 'CERTIFICATE_VERIFY_FAILED' in str(e):
            logging.info("Hint: Check if the certificate is in the system's trust store or a Java keystore.")
            logging.info("Hint: If running inside Ansible, try passing REQUESTS_CA_BUNDLE to point to the host bundle.")
    except requests.exceptions.RequestException as e:
        logging.error(f"✗ Connection Error with requests: {e}")
    return False
{% endraw %}

# =============================================================================
# Main Entrypoint
# =============================================================================

def main():
    # Define default value from templated Ansible variable
    default_url = "{{ deploy_pki_certs__validation_url }}"

    parser = argparse.ArgumentParser(
        description="Validate a TLS/SSL connection to a specific URL utilizing native Python features and `requests`.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter
    )

    parser.add_argument(
        "url",
        nargs="?",
        default=default_url,
        help="The target validation HTTPS URL to test."
    )
    parser.add_argument(
        "-v", "--verbose",
        action="store_true",
        help="Enable verbose debugging output."
    )

    args = parser.parse_args()
    setup_logging(verbose=args.verbose)

    logging.info(f"Starting SSL connection validation process...")

    # Run standard library check
    success = validate_with_http_client(args.url)

    # Run requests library check if installed
    if HAS_REQUESTS:
        print("-" * 40)
        success &= validate_with_requests(args.url)

    if not success:
        logging.critical("One or more SSL validation checks FAILED.")
        sys.exit(1)

    logging.info("All SSL validation checks PASSED successfully.")


if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print("\nExecution interrupted by user. Exiting.", file=sys.stderr)
        sys.exit(130)

# {{ ansible_managed }}

server:
  host: "0.0.0.0"
  port: {{ bootstrap_llm_host__nemoclaw_port }}

inference:
  provider: "ollama"
  endpoint: "http://127.0.0.1:{{ bootstrap_llm_host__ollama_port }}"
  default_model: "{{ bootstrap_llm_host__nemoclaw_orchestration_model }}"

openshell:
  sandbox_root: "{{ bootstrap_llm_host__nemoclaw_sandbox_root }}"
  workspace_dir: "{{ bootstrap_llm_host__nemoclaw_workspace_dir }}"

  # Enforcement profiles to manage infrastructure safely
  security_policies:
    allow_network_egress: true
    require_human_approval:
      - "systemctl"
      - "rm -rf"
      - "iptables"

integrations:
  webhooks_enabled: true

{{ 'Ansible managed' | comment(format="# {}") }}
# /etc/nslcd.conf
# nslcd configuration file. See nslcd.conf(5)
# for details.

# The user and group nslcd should run as.
uid {{ __ldap_conf.nslcd_uid }}
gid {{ __ldap_conf.nslcd_gid }}

# The location at which the LDAP server(s) should be reachable.
#uri ldap://{{ bootstrap_ldap_client__server_host }}/
uri {{ bootstrap_ldap_client__uri }}

# The search base that will be used for all queries.
base {{ bootstrap_ldap_client__base_dn }}

{% if bootstrap_ldap_client__nslcd_filter %}
{% for key, value in bootstrap_ldap_client__nslcd_filter.items() %}
{% for item, filter in value.items() %}
{{ key }} {{ item }} {{ filter }}
{% endfor %}
{% endfor %}
{% endif %}

#The LDAP protocol version to use.
#ldap_version 3

{% if bootstrap_ldap_client__binddn %}
# The DN to bind with for normal lookups.
binddn {{ bootstrap_ldap_client__binddn }}
{% if bootstrap_ldap_client__bindpw %}
bindpw {{ bootstrap_ldap_client__bindpw }}
{% endif %}
{% endif %}

# The DN used for password modifications by root.
#rootpwmoddn cn=admin,{{ bootstrap_ldap_client__base_dn }}

# SSL options
#ssl off
#tls_reqcert never

# The search scope.
#scope sub


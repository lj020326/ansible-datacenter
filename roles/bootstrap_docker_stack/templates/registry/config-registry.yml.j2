version: 0.1
log:
  fields:
    service: registry
storage:
  cache:
    blobdescriptor: inmemory
  filesystem:
    rootdirectory: /var/lib/registry
  delete:
      enabled: true
http:
  addr: :5000
  headers:
    X-Content-Type-Options: [nosniff]
health:
  storagedriver:
    enabled: true
    interval: 10s
    threshold: 3

{% if __docker_stack__registry__enable_passthru %}
## ref: https://docs.docker.com/registry/recipes/mirror/
## ref: https://docs.docker.com/registry/configuration/
proxy:
  remoteurl: {{ __docker_stack__registry__proxy_remote_url }}
{% if __docker_stack__registry__proxy_remote_username | length > 0 and
    __docker_stack__registry__proxy_remote_password | length > 0 %}
  username: {{ __docker_stack__registry__proxy_remote_username }}
  password: {{ __docker_stack__registry__proxy_remote_password }}
{% endif %}
{% endif %}
